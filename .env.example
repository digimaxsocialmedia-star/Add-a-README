# =============================================================================
# AdPilot environment configuration
# =============================================================================
# The app runs in DEMO mode (mock data) unless you set BOTH
# META_ACCESS_TOKEN and META_AD_ACCOUNT_ID below — then it switches to LIVE
# mode and talks to the real Meta (Facebook) Marketing API.
# =============================================================================

# --- AI Insights (optional in both modes) -----------------------------------
# If set, the "AI Insights" feature calls Claude for real recommendations.
# Without it, a built-in heuristic optimizer is used so the feature still works.
ANTHROPIC_API_KEY=

# --- Meta Marketing API (LIVE mode) -----------------------------------------
# Required to enable live mode:
META_ACCESS_TOKEN=          # long-lived token with ads_read (+ ads_management for writes)
META_AD_ACCOUNT_ID=         # e.g. act_1234567890  (the "act_" prefix is optional)

# Optional (sensible defaults shown):
META_API_VERSION=v23.0      # Graph API version, e.g. v23.0
META_INSIGHTS_DATE_PRESET=last_30d   # last_7d | last_14d | last_30d | last_90d | maximum
# Which insights action type counts as a "conversion"/"revenue". Defaults to
# trying purchase, omni_purchase, offsite_conversion.fb_pixel_purchase in order.
# Set this to match your pixel/CAPI setup if conversions look wrong, e.g.:
#   META_CONVERSION_ACTION_TYPE=offsite_conversion.fb_pixel_purchase
META_CONVERSION_ACTION_TYPE=
# Optional — only needed if you extend campaign creation to build creatives/ads.
META_PAGE_ID=
