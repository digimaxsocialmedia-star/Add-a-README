# =============================================================================
# AdPilot environment configuration
# =============================================================================
# The app runs in DEMO mode (mock data) unless you set BOTH
# META_ACCESS_TOKEN and META_AD_ACCOUNT_ID below — then it switches to LIVE
# mode and talks to the real Meta (Facebook) Marketing API.
# =============================================================================

# --- AI Insights (optional in both modes) -----------------------------------
# If set, the "AI Insights" feature calls Claude for real recommendations.
# Without it, a built-in heuristic optimizer is used so the feature still works.
ANTHROPIC_API_KEY=

# --- Báo cáo qua email (tùy chọn) --------------------------------------------
# Chưa cấu hình thì nút "Gửi ngay" chỉ hiện bản xem trước (demo vẫn dùng được).
# Ví dụ với Gmail: tạo "App password" và dùng smtp.gmail.com:587.
SMTP_HOST=            # vd smtp.gmail.com
SMTP_PORT=587        # 587 (STARTTLS) hoặc 465 (SSL)
SMTP_SECURE=false    # true nếu dùng cổng 465
SMTP_USER=           # email đăng nhập SMTP
SMTP_PASS=           # mật khẩu ứng dụng (App password)
REPORT_EMAIL_FROM=   # địa chỉ người gửi (mặc định = SMTP_USER)
REPORT_EMAIL_TO=     # địa chỉ nhận mặc định (khi cron gọi GET /api/report/email)

# --- Cảnh báo tức thì qua Telegram / Zalo (tùy chọn) -------------------------
# Telegram: tạo bot với @BotFather để lấy token; nhắn cho bot rồi lấy chat_id
# (vd qua https://api.telegram.org/bot<token>/getUpdates).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Zalo Official Account: cần access token của OA và user_id người nhận
# (người dùng phải đã tương tác với OA để nhận tin CS).
ZALO_OA_ACCESS_TOKEN=
ZALO_USER_ID=

# --- Meta Marketing API (LIVE mode) -----------------------------------------
# Required to enable live mode:
META_ACCESS_TOKEN=          # long-lived token with ads_read (+ ads_management for writes)
META_AD_ACCOUNT_ID=         # e.g. act_1234567890  (the "act_" prefix is optional)

# Optional (sensible defaults shown):
META_API_VERSION=v23.0      # Graph API version, e.g. v23.0
META_INSIGHTS_DATE_PRESET=last_30d   # last_7d | last_14d | last_30d | last_90d | maximum
# Hệ số quy đổi đơn vị tiền của tài khoản. USD/EUR = 100 (cents).
# TÀI KHOẢN VND: đặt = 1 (VND không có đơn vị lẻ) để ngân sách hiển thị đúng.
META_CURRENCY_OFFSET=1
# Which insights action type counts as a "conversion"/"revenue". Defaults to
# trying purchase, omni_purchase, offsite_conversion.fb_pixel_purchase in order.
# Set this to match your pixel/CAPI setup if conversions look wrong, e.g.:
#   META_CONVERSION_ACTION_TYPE=offsite_conversion.fb_pixel_purchase
META_CONVERSION_ACTION_TYPE=
# --- Tạo quảng cáo đầy đủ ở live mode (Chiến dịch → Nhóm QC → Creative → QC) ---
# ID Trang Facebook. BẮT BUỘC nếu muốn tạo cả creative + quảng cáo (không có
# thì chỉ tạo Chiến dịch + Nhóm QC ở trạng thái PAUSED).
META_PAGE_ID=
# ID Pixel. Tùy chọn — nếu có, chiến dịch mục tiêu Doanh số sẽ tối ưu theo
# chuyển đổi (OFFSITE_CONVERSIONS / PURCHASE); không có thì tối ưu theo lượt nhấp.
META_PIXEL_ID=
# Quốc gia nhắm chọn mặc định cho nhóm QC mới (mã ISO). Mặc định VN.
META_TARGETING_COUNTRY=VN
